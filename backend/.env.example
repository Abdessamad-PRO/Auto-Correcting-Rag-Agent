# ============================================================================
# LLM provider selection.
#
# Resolution order (first match wins):
#   1. LOCAL=true                   → use Ollama as primary (no API key needed)
#   2. LLM_PROVIDER=<name>          → that provider (must have its key, except ollama)
#   3. First non-empty API key:     GEMINI_API_KEY → OPENAI_API_KEY → GROK_API_KEY
#   4. Nothing remote configured?   → falls back to Ollama
#
# The active provider is the PRIMARY; the rest of the configured providers
# become automatic fallbacks via LangChain's `Runnable.with_fallbacks(...)`.
# When the primary hits 429 / 5xx / quota, the chain silently advances:
#
#   gemini-flash-latest  →  gemini-pro-latest  →  ollama:gemma  →  ollama:deepseek
#
# This means a free-tier rate-limit on Gemini transparently falls through to
# your local Ollama models — no user-visible failure.
# ============================================================================

# LLM_PROVIDER=gemini   # one of: gemini | openai | grok | ollama (optional override)
# LOCAL=true            # shortcut for LLM_PROVIDER=ollama (forces local-first)

# --- Google Gemini ---
GEMINI_API_KEY=
# Use a currently-served model. As of 2026 the stable family aliases are
# `gemini-flash-latest` (fast, balanced) and `gemini-pro-latest` (most capable).
GEMINI_MODEL=gemini-flash-latest
# Same-provider fallback — tried when GEMINI_MODEL is rate-limited or errors.
GEMINI_FALLBACK_MODEL=gemini-pro-latest
# Stable embedding model on v1beta. Wipe chroma_db/ if you change this.
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- xAI Grok ---
GROK_API_KEY=
# Currently-served xAI models: grok-4, grok-4-fast-reasoning, grok-4-fast-non-reasoning,
# grok-3, grok-3-mini, grok-code-fast-1. See https://console.x.ai/.
GROK_MODEL=grok-4-fast-reasoning
# Grok has no embedding API — when grok is selected, embeddings fall back to
# the local HuggingFace model below.
LOCAL_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================================
# Ollama — local LLM daemon. Used either as the primary (LOCAL=true or
# LLM_PROVIDER=ollama) or as a last-resort fallback when remote APIs throw
# 429 / 5xx. Either way, the daemon must be running and the listed models
# must already be pulled (`ollama list` shows what you have).
#
# Pull once:
#     ollama pull gemma
#     ollama pull deepseek-r1
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434

# The primary Ollama model — used when LOCAL=true OR every remote provider
# is exhausted. Must match a tag from `ollama list` exactly.
OLLAMA_MODEL=gemma:latest

# Additional Ollama models tried after OLLAMA_MODEL fails. Comma-separated.
OLLAMA_FALLBACK_MODELS_RAW=deepseek-r1:latest

# Ollama model used to produce vector embeddings. If empty, OLLAMA_MODEL is
# reused. For better retrieval quality pull a dedicated embed model first:
#     ollama pull nomic-embed-text
# then set OLLAMA_EMBED_MODEL=nomic-embed-text below.
OLLAMA_EMBED_MODEL=

# ============================================================================
# Vector store
# ============================================================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=gcn_eeg_papers
RETRIEVER_TOP_K=5

# ============================================================================
# Web search tool (used when vector retrieval is weak)
# ============================================================================
# WEB_SEARCH_PROVIDER one of: duckduckgo | tavily   (default: duckduckgo, no key needed)
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# ============================================================================
# Agent behaviour
# ============================================================================
MAX_RETRIEVE_ITERATIONS=3
RELEVANCE_THRESHOLD=0.5
LLM_TEMPERATURE=0.0

# ============================================================================
# API server
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated list of allowed CORS origins for the Angular frontend
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
LOG_LEVEL=INFO
